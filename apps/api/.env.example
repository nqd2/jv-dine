NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://jvdine:jvdine@localhost:5432/jv_dine?schema=public
DIRECT_URL=postgresql://jvdine:jvdine@localhost:5432/jv_dine?schema=public
JWT_SECRET=
JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=

WEB_ORIGIN=http://localhost:3000

# Cloudflare R2 (script: pnpm --filter api upload:r2-restaurant-images)
# Endpoint S3 API — ưu tiên dòng này; nếu trống thì dùng R2_ACCOUNT_ID ghép URL
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL của bucket (r2.dev / custom domain), không có dấu / cuối — bắt buộc để URL ảnh trong DB đúng
R2_PUBLIC_BASE_URL=

# Upstash Redis (optional) — caches GET /restaurants/search responses
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
